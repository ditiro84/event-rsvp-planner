# --- Database ---
# Local dev (docker-compose): postgresql://postgres:postgres@localhost:5432/eventapp?schema=public
# Production (Neon/Railway): use the connection string provided by your DB host, include sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventapp?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="event_rsvp_token"

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:5173"

# --- Public app URL (used to build RSVP links) ---
PUBLIC_APP_URL="http://localhost:5173"

# --- Rate limiting ---
RSVP_RATE_LIMIT_MAX=20
RSVP_RATE_LIMIT_WINDOW_MS=900000

# --- Invite emails (optional) ---
# Enables the "Email invite" button and bulk invite sending. Get an API key
# at https://resend.com and verify a sending domain there first.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="EventFlow <invites@yourdomain.com>"

# --- Merchandise checkout (optional) ---
# Enables the guest-facing shop/checkout. Without these set, the Merchandise
# tab still works for managing products, but checkout will fail with a clear
# "not configured" error instead of silently doing nothing.
# Get keys at https://dashboard.stripe.com/apikeys (use test keys while
# developing). The webhook secret comes from the endpoint you register at
# https://dashboard.stripe.com/webhooks pointing to POST /api/webhooks/stripe,
# listening for the checkout.session.completed event.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CURRENCY=usd

# --- Future integrations (not yet wired) ---
# SMS_PROVIDER_API_KEY=
# STORAGE_BUCKET_URL=
