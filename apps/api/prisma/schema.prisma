// Event RSVP & Visual Seating Planner - Database Schema
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// USERS / AUTH
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events        Event[]
  notifications Notification[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// EVENTS
// ---------------------------------------------------------------------------

enum EventType {
  WEDDING
  BIRTHDAY
  CORPORATE
  CONFERENCE
  GRADUATION
  PARTY
  GALA
  RELIGIOUS
  CHARITY
  OTHER
}

model Event {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  type        EventType @default(OTHER)
  description String?
  date        DateTime
  startTime   String?
  endTime     String?
  venueName   String?
  venueAddress String?
  capacity    Int?
  imageUrl    String?

  // Public RSVP configuration
  rsvpToken       String    @unique @default(cuid())
  rsvpOpen        Boolean   @default(true)
  rsvpDeadline    DateTime?
  customMessage   String?

  // RSVP form feature toggles
  allowPlusOnes         Boolean @default(true)
  allowPlusOneNames      Boolean @default(true)
  allowMealSelection     Boolean @default(true)
  allowDietary           Boolean @default(true)
  allowAccessibilityInfo Boolean @default(true)
  allowSpecialRequests   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guests          Guest[]
  rsvpQuestions   RSVPQuestion[]
  invitations     EventInvitation[]
  venueLayout     VenueLayout?
  tables          Table[]
  checkIns        CheckIn[]
  invitationCard  EventInvitationCard?
  vendors         Vendor[]
  notifications   Notification[]
  products        Product[]
  orders          Order[]

  // "Shop Enabled" toggle on the Merchandise dashboard -- guests only see
  // the purchase flow on their RSVP page once this is on, so a planner can
  // set products up before going live.
  merchandiseEnabled Boolean @default(false)

  @@index([userId])
  @@map("events")
}

// ---------------------------------------------------------------------------
// GUESTS / RSVP
// ---------------------------------------------------------------------------

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  MAYBE
}

model Guest {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  email     String?
  phone     String?
  groupName String?

  rsvpStatus            RsvpStatus @default(PENDING)
  rsvpRespondedAt        DateTime?
  additionalGuestsCount  Int        @default(0)
  mealPreference         String?
  dietaryRequirements    String?
  accessibilityRequirements String?
  specialNotes           String?
  isVip                  Boolean    @default(false)

  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party            GuestParty[]
  rsvpAnswers      RSVPAnswer[]
  invitation       EventInvitation?
  seatAssignment   SeatingAssignment?
  checkIn          CheckIn?
  orders           Order[]

  @@index([eventId])
  @@index([eventId, rsvpStatus])
  @@index([eventId, email])
  @@map("guests")
}

// Accompanying guests brought by a primary guest ("+1"s, family members, etc.)
// Each party member is a named individual and, like the primary guest, can
// hold their own seat assignment on the venue map (see PartySeatingAssignment).
model GuestParty {
  id      String @id @default(cuid())
  guestId String
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  fullName            String
  mealPreference      String?
  dietaryRequirements String?

  createdAt DateTime @default(now())

  seatAssignment PartySeatingAssignment?

  @@index([guestId])
  @@map("guest_party_members")
}

// A host-designed invitation card (PDF or image) attached to invite emails
// and linked in WhatsApp invite messages. One per event, stored directly in
// Postgres (bytea) rather than an external bucket -- these files are small
// (capped in the upload handler) and this avoids needing a separate storage
// service/credentials. Kept in its own table (not columns on Event) so
// normal Event queries never pull these bytes along for the ride.
model EventInvitationCard {
  id       String @id @default(cuid())
  eventId  String @unique
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  data     Bytes
  mimeType String
  fileName String
  size     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("event_invitation_cards")
}

// Optional per-guest personalised invitation link (future: email/SMS sending).
// The MVP primarily uses the event-level rsvpToken; this scaffolds 1:1 invites.
model EventInvitation {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestId   String?   @unique
  guest     Guest?    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  token     String    @default(cuid()) @unique
  channel   String?   // email | sms | whatsapp | manual
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([eventId])
  @@map("event_invitations")
}

// Configurable custom RSVP questions (future extension beyond the built-in fields)
model RSVPQuestion {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  label     String
  type      String   @default("text") // text | select | boolean
  options   String?  // JSON-encoded array of options for "select"
  required  Boolean  @default(false)
  order     Int      @default(0)

  answers RSVPAnswer[]

  @@index([eventId])
  @@map("rsvp_questions")
}

model RSVPAnswer {
  id         String       @id @default(cuid())
  guestId    String
  guest      Guest        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  questionId String
  question   RSVPQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answerText String?
  createdAt  DateTime @default(now())

  @@unique([guestId, questionId])
  @@map("rsvp_answers")
}

// ---------------------------------------------------------------------------
// VENUE / SEATING
// ---------------------------------------------------------------------------

enum LayoutObjectType {
  STAGE
  DANCE_FLOOR
  BAR
  BUFFET
  ENTRANCE
  EXIT
  TOILETS
  DJ_BOOTH
  VIP_AREA
  CUSTOM
}

model VenueLayout {
  id      String @id @default(cuid())
  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name          String  @default("Main Layout")
  canvasWidth   Int     @default(1600)
  canvasHeight  Int     @default(1000)
  gridSize      Int     @default(20)
  backgroundColor String @default("#f8fafc")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  objects LayoutObject[]

  @@map("venue_layouts")
}

model LayoutObject {
  id            String           @id @default(cuid())
  venueLayoutId String
  venueLayout   VenueLayout      @relation(fields: [venueLayoutId], references: [id], onDelete: Cascade)

  type     LayoutObjectType @default(CUSTOM)
  label    String?
  x        Float            @default(0)
  y        Float            @default(0)
  width    Float            @default(100)
  height   Float            @default(100)
  rotation Float            @default(0)
  color    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueLayoutId])
  @@map("layout_objects")
}

enum TableShape {
  ROUND
  SQUARE
  RECTANGLE
  OVAL
  BANQUET
  HEAD
  CUSTOM
}

model Table {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name     String
  shape    TableShape @default(ROUND)
  capacity Int        @default(8)
  x        Float      @default(0)
  y        Float      @default(0)
  width    Float      @default(120)
  height   Float      @default(120)
  rotation Float       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seats                   Seat[]
  seatingAssignments      SeatingAssignment[]
  partySeatingAssignments PartySeatingAssignment[]

  @@index([eventId])
  @@map("tables")
}

model Seat {
  id      String @id @default(cuid())
  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  seatNumber Int
  x          Float @default(0)
  y          Float @default(0)

  assignment      SeatingAssignment?
  partyAssignment PartySeatingAssignment?

  @@unique([tableId, seatNumber])
  @@index([tableId])
  @@map("seats")
}

model SeatingAssignment {
  id      String @id @default(cuid())
  guestId String @unique
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  seatId  String? @unique
  seat    Seat?  @relation(fields: [seatId], references: [id], onDelete: SetNull)

  assignedAt DateTime @default(now())

  @@index([tableId])
  @@map("seating_assignments")
}

// A named party member's ("+1"'s) own seat -- mirrors SeatingAssignment but
// points at a GuestParty row instead of a Guest, so each accompanying guest
// gets a real, independent seat on the venue map next to the guest who
// invited them.
model PartySeatingAssignment {
  id            String     @id @default(cuid())
  partyMemberId String     @unique
  partyMember   GuestParty @relation(fields: [partyMemberId], references: [id], onDelete: Cascade)
  tableId       String
  table         Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  seatId        String?    @unique
  seat          Seat?      @relation(fields: [seatId], references: [id], onDelete: SetNull)

  assignedAt DateTime @default(now())

  @@index([tableId])
  @@map("party_seating_assignments")
}

// ---------------------------------------------------------------------------
// CHECK-IN
// ---------------------------------------------------------------------------

model CheckIn {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestId String @unique
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  checkedInAt DateTime @default(now())
  checkedInBy String?

  @@index([eventId])
  @@map("check_ins")
}

// Relation from Table -> SeatingAssignment (reverse, needed for onDelete cascade clarity)

// ---------------------------------------------------------------------------
// VENDORS
// ---------------------------------------------------------------------------

enum VendorCategory {
  CATERING
  VENUE
  PHOTOGRAPHY
  VIDEOGRAPHY
  FLORAL
  MUSIC_ENTERTAINMENT
  DECOR
  RENTALS
  TRANSPORTATION
  BEAUTY
  STATIONERY
  OTHER
}

enum VendorStatus {
  CONTACTED
  QUOTE_RECEIVED
  BOOKED
  CONFIRMED
  CANCELLED
}

model Vendor {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String
  category    VendorCategory @default(OTHER)
  status      VendorStatus   @default(CONTACTED)
  contactName String?
  email       String?
  phone       String?
  website     String?
  // Minor currency units (e.g. cents), not a float, to avoid rounding drift.
  costCents   Int?
  depositPaid Boolean @default(false)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@map("vendors")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

enum NotificationType {
  RSVP_CONFIRMED
  RSVP_DECLINED
  VENDOR_STATUS_CHANGED
  ORDER_PAID
  SYSTEM
}

model Notification {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String?
  // Frontend route to deep-link into when the notification is clicked,
  // e.g. "/events/:eventId/guests".
  link  String?

  read   Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([eventId])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// MERCHANDISE (event shop)
// ---------------------------------------------------------------------------

// A single sellable item on an event's shop (e.g. favour boxes, t-shirts).
// One optional image, stored the same way as EventInvitationCard (bytes in
// Postgres) rather than an external bucket -- consistent with the rest of
// this app and avoids needing separate storage credentials.
model Product {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String
  description String?
  // Minor currency units (cents), not a float, to avoid rounding drift --
  // same convention as Vendor.costCents.
  priceCents  Int
  // Null = unlimited stock. Decremented when an order for this product is
  // marked PAID (see markOrderPaid in orders.service.ts).
  stockQuantity Int?
  // Hidden from the guest-facing shop without deleting the product (and its
  // order history) outright.
  active      Boolean @default(true)

  imageData     Bytes?
  imageMimeType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([eventId])
  @@map("products")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

// A guest's purchase. Created in PENDING state when a Stripe Checkout
// Session is opened, then flipped to PAID by the Stripe webhook once
// payment actually clears -- never marked PAID from a client-trusted call.
model Order {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestId String?
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  // Captured directly (not just via guestId) so an order is still
  // identifiable even if the guest record is later removed, and so a guest
  // who hasn't been matched to a Guest row yet can still check out.
  guestName  String
  guestEmail String

  status        OrderStatus @default(PENDING)
  totalCents    Int
  deliveryMethod String @default("AT_EVENT") // AT_EVENT | SHIPPING (future)

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([eventId])
  @@index([eventId, status])
  @@map("orders")
}

// Line item snapshot -- name/price captured at time of purchase so a later
// product edit (renamed, repriced) doesn't rewrite order history.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productName     String
  unitPriceCents  Int
  quantity        Int

  @@index([orderId])
  @@map("order_items")
}

